{"type":"message","id":"70e20ca0","parentId":"3aa4a3c8","timestamp":"2026-04-10T06:47:00.220Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the core monitoring service for this agent.","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n"},{"type":"toolCall","id":"call_function_rl620agp32h2_1","name":"write","arguments":{"content":"/**\n * monitorService.ts — 监控助手的核心服务\n * 职责：检测停滞 → 决策是否督促 → 执行督促 → 记录日志\n */\n\nimport { execSync } from 'child_process'\nimport { readFileSync } from 'fs'\nimport { resolve } from 'path'\n\n// ============= 配置加载 =============\nexport interface MonitorConfig {\n  project: {\n    name: string\n    gitRepo: string\n    mainBranch: string\n    branches: string[]\n  }\n  thresholds: {\n    noCommitHours: number\n    ciFailureHours: number\n    taskOverdueDays: number\n    prReviewHours: number\n    blockerHours: number\n    demandConfirmDays: number\n  }\n  notifyees: {\n    manager: string\n    default: string\n  }\n}\n\nlet _config: MonitorConfig | null = null\n\nexport function loadConfig(configPath?: string): MonitorConfig {\n  if (_config) return _config\n  const file = configPath || resolve(__dirname, '../../projects/monitor/config.json')\n  _config = JSON.parse(readFileSync(file, 'utf-8')) as MonitorConfig\n  return _config\n}\n\n// ============= 停滞检测 =============\n\nexport interface StagnationItem {\n  type: 'git' | 'ci' | 'task' | 'pr' | 'blocker' | 'demand'\n  severity: 'warning' | 'critical'\n  message: string\n  detail: string\n  owner?: string        // 飞书 open_id\n  ownerName?: string\n  hoursOverdue?: number\n  url?: string\n}\n\nexport interface HealthReport {\n  projectName: string\n  timestamp: string\n  overall: 'healthy' | 'warning' | 'critical'\n  score: number          // 0-100\n  issues: StagnationItem[]\n  lastCommitTime?: string\n  lastCommitBranch?: string\n  ciStatus?: 'passing' | 'failing' | 'unknown'\n  recentCommits?: { hash: string; message: string; author: string; time: string }[]\n}\n\n/**\n * 检测 Git 提交活跃度\n */\nexport function checkGitActivity(config: MonitorConfig): StagnationItem[] {\n  const issues: StagnationItem[] = []\n  const { gitRepo, mainBranch } = config.project\n\n  try {\n    // 获取各分支最新提交时间\n    const branches = [mainBranch, ...config.project.branches]\n    const now = Date.now()\n    const thresholdMs = config.thresholds.noCommitHours * 3600 * 1000\n\n    for (const branch of branches) {\n      const output = execSync(\n        `git log ${branch} -1 --format=\"%H|%s|%an|%ai\" --since=\"${config.thresholds.noCommitHours} hours ago\" 2>/dev/null || echo \"\"`,\n        { cwd: gitRepo, encoding: 'utf-8', timeout: 10000 }\n      ).trim()\n\n      if (!output) {\n        // 没有最近提交，尝试获取最后一次提交的绝对时间\n        const lastCommit = execSync(\n          `git log ${branch} -1 --format=\"%H|%s|%an|%ai\" 2>/dev/null || echo \"\"`,\n          { cwd: gitRepo, encoding: 'utf-8', timeout: 10000 }\n        ).trim()\n\n        if (lastCommit) {\n          const [hash, msg, author, dateStr] = lastCommit.split('|')\n          const commitTime = new Date(dateStr).getTime()\n          const hoursAgo = (now - commitTime) / 3600000\n\n          if (hoursAgo > config.thresholds.noCommitHours) {\n            issues.push({\n              type: 'git',\n              severity: hoursAgo > config.thresholds.noCommitHours * 2 ? 'critical' : 'warning',\n              message: `分支 ${branch} 已经 ${Math.floor(hoursAgo)} 小时没有新提交`,\n              detail: `最后提交：[${hash.slice(0, 7)}] ${msg} by ${author} (${dateStr})`,\n              hoursOverdue: Math.floor(hoursAgo),\n              url: `${gitRepo}/commits/${branch}`,\n            })\n          }\n        }\n      }\n    }\n  } catch (err) {\n    // Git 仓库不可访问或仓库路径无效，静默跳过\n    console.warn('[Monitor] Git 检查失败:', err)\n  }\n\n  return issues\n}\n\n/**\n * 获取最近提交记录（用于健康度报告）\n */\nexport function getRecentCommits(config: MonitorConfig, count = 5): HealthReport['recentCommits'] {\n  try {\n    const output = execSync(\n      `git log -${count} --format=\"%H|%s|%an|%ai\" 2>/dev/null || echo \"\"`,\n      { cwd: config.project.gitRepo, encoding: 'utf-8', timeout: 10000 }\n    ).trim()\n\n    if (!output) return []\n\n    return output.split('\\n').map((line) => {\n      const [hash, message, author, time] = line.split('|')\n      return { hash: hash.slice(0, 7), message, author, time }\n    })\n  } catch {\n    return []\n  }\n}\n\n/**\n * 生成项目健康度报告\n */\nexport function generateHealthReport(config: MonitorConfig): HealthReport {\n  const gitIssues = checkGitActivity(config)\n  const recentCommits = getRecentCommits(config)\n  const lastCommit = recentCommits?.[0]\n\n  // 计算健康分\n  let score = 100\n  for (const issue of gitIssues) {\n    score -= issue.severity === 'critical' ? 20 : 10\n  }\n  score = Math.max(0, score)\n\n  const overall = score >= 80 ? 'healthy' : score >= 50 ? 'warning' : 'critical'\n\n  return {\n    projectName: config.project.name,\n    timestamp: new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' }),\n    overall,\n    score,\n    issues: gitIssues,\n    lastCommitTime: lastCommit?.time,\n    lastCommitBranch: config.project.mainBranch,\n    recentCommits,\n  }\n}\n\n/**\n * 判断是否需要升级督促（多次催促未响应）\n */\nexport function shouldEscalate(\n  issueType: string,\n  owner: string,\n  urgeCount: number\n): { escalate: boolean; level: 1 | 2 | 3 } {\n  if (urgeCount === 0) return { escalate: true, level: 1 }\n  if (urgeCount === 1) return { escalate: true, level: 2 }  // 10分钟后第二次\n  if (urgeCount >= 2) return { escalate: true, level: 3 }   // 30分钟后第三次，上报\n  return { escalate: false, level: 1 }\n}\n\n// ============= 督促消息模板 =============\n\nexport function buildUrgeMessage(\n  item: StagnationItem,\n  level: 1 | 2 | 3,\n  projectName: string\n): string {\n  const urgencyText = level === 1 ? '温馨提示' : level === 2 ? '请注意' : '⚠️ 重要提醒'\n  const projectLine = `📦 项目：${projectName}`\n\n  if (item.type === 'git') {\n    return `${urgencyText}\n\n${projectLine}\n${item.message}\n\n${item.detail}\n\n请尽快推进，有问题及时同步阻塞原因。`\n  }\n\n  if (item.type === 'ci') {\n    return `${urgencyText}\n\n${projectLine}\nCI/CD 流水线持续失败已超过 ${item.hoursOverdue} 小时\n\n${item.detail}\n\n请优先处理，保持流水线畅通。`\n  }\n\n  if (item.type === 'task') {\n    return `${urgencyText}\n\n${projectLine}\n${item.message}\n\n${item.detail}\n\n请尽快处理或更新状态。`\n  }\n\n  return `${urgencyText}\n\n${projectLine}\n${item.message}\n\n${item.detail}`\n}\n","path":"/home/gem/workspace/agent/workspace/agents/monitor/src/monitorService.ts"}}],"api":"openai-completions","provider":"miaoda","model":"miaoda-model-auto","usage":{"input":324,"output":1769,"cacheRead":89147,"cacheWrite":0,"totalTokens":91240,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803579275,"responseId":"chatcmpl-654ef362-4891-48c8-85f4-efc2ad250e0c"}}
{"type":"message","id":"53abff67","parentId":"70e20ca0","timestamp":"2026-04-10T06:47:00.235Z","message":{"role":"toolResult","toolCallId":"call_function_rl620agp32h2_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 5823 bytes to /home/gem/workspace/agent/workspace/agents/monitor/src/monitorService.ts"}],"isError":false,"timestamp":1775803620232}}
{"type":"message","id":"4c8ea9c0","parentId":"53abff67","timestamp":"2026-04-10T06:47:22.946Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the main monitor agent that ties everything together.","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n"},{"type":"toolCall","id":"call_function_m4iau42i5qf9_1","name":"write","arguments":{"content":"/**\n * monitorAgent.ts — 监控助手主入口\n * 负责：加载配置 → 扫描状态 → 生成报告 → 执行督促\n */\n\nimport { loadConfig, generateHealthReport, buildUrgeMessage, StagnationItem } from './monitorService'\nimport { feishu_im_user_message } from '../../../src/lark-tools' // 飞书消息工具\n\nexport interface MonitorResult {\n  report: ReturnType<typeof generateHealthReport>\n  urges: UrgeRecord[]\n}\n\nexport interface UrgeRecord {\n  item: StagnationItem\n  level: 1 | 2 | 3\n  sent: boolean\n  error?: string\n}\n\n// ============= 核心主函数 =============\n\n/**\n * 执行一次完整的项目监控\n * 1. 扫描各维度状态\n * 2. 生成健康度报告\n * 3. 对停滞项执行督促\n */\nexport async function runMonitorCycle(): Promise<MonitorResult> {\n  const config = loadConfig()\n  const report = generateHealthReport(config)\n\n  const urgeRecords: UrgeRecord[] = []\n\n  // 对每个停滞项发送督促\n  for (const issue of report.issues) {\n    const { level } = { escalate: true, level: 1 as const }\n    const message = buildUrgeMessage(issue, level, config.project.name)\n\n    try {\n      if (issue.owner) {\n        await sendUrgeMessage(issue.owner, message)\n        urgeRecords.push({ item: issue, level, sent: true })\n      } else {\n        // 没有指定责任人，发给默认接收人\n        await sendUrgeMessage(config.notifyees.default, message)\n        urgeRecords.push({ item: issue, level, sent: true })\n      }\n    } catch (err: any) {\n      urgeRecords.push({ item: issue, level, sent: false, error: err.message })\n    }\n  }\n\n  return { report, urges: urgeRecords }\n}\n\n/**\n * 发送飞书督促消息\n */\nasync function sendUrgeMessage(openId: string, message: string): Promise<void> {\n  await feishu_im_user_message({\n    action: 'send',\n    msg_type: 'text',\n    content: JSON.stringify({ text: message }),\n    receive_id: openId,\n    receive_id_type: 'open_id',\n  })\n}\n\n/**\n * 生成健康度报告文本（给人类看的格式）\n */\nexport function formatHealthReport(report: ReturnType<typeof generateHealthReport>): string {\n  const emoji = report.overall === 'healthy' ? '✅' : report.overall === 'warning' ? '⚠️' : '🔴'\n  const scoreColor = report.score >= 80 ? '良好' : report.score >= 50 ? '一般' : '较差'\n\n  let text = `${emoji} 项目健康度报告：${report.projectName}\n\n━━━━━━━━━━━━━━━━━━━\n🕐 时间：${report.timestamp}\n📊 综合评分：${report.score}/100（${scoreColor}）\n━━━━━━━━━━━━━━━━━━━`\n\n  if (report.lastCommitTime) {\n    text += `\\n📝 最近提交：${report.lastCommitTime}`\n  }\n\n  if (report.issues.length === 0) {\n    text += `\\n\\n🎉 项目运行正常，暂无停滞风险`\n  } else {\n    text += `\\n\\n🚨 停滞风险（${report.issues.length} 项）：`\n    for (const issue of report.issues) {\n      const sev = issue.severity === 'critical' ? '🔴' : '⚠️'\n      text += `\\n${sev} ${issue.message}\\n   ${issue.detail}`\n    }\n  }\n\n  return text\n}\n\n// ============= 命令行入口 =============\n// 如需在终端直接运行：npx tsx src/monitorAgent.ts\n\nif (import.meta.url === `file://${process.argv[1]}`) {\n  const result = await runMonitorCycle()\n  console.log(formatHealthReport(result.report))\n  console.log(`\\n督促记录：${result.urges.filter(u => u.sent).length}/${result.urges.length} 条发送成功`)\n}\n","path":"/home/gem/workspace/agent/workspace/agents/monitor/src/monitorAgent.ts"}}],"api":"openai-completions","provider":"miaoda","model":"miaoda-model-auto","usage":{"input":343,"output":931,"cacheRead":90939,"cacheWrite":0,"totalTokens":92213,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803620237,"responseId":"chatcmpl-2062eab3-4b79-4959-9b38-be3e5a42713a"}}
